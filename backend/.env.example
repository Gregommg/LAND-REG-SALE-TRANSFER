# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=land_registration_db
DB_USER=postgres
DB_PASSWORD=GAMER73
# Set to "true" when connecting to an external provider that requires SSL
# (Neon, Supabase, etc. - basically anything that isn't your own local
# Postgres or Render's internal Postgres). Leave "false" for local dev.
DB_SSL=false

# JSON Web Token
JWT_SECRET=change_this_to_a_long_random_secret_before_deploying
JWT_EXPIRES_IN=8h

# Private messaging encryption (AES-256-GCM key, 32 bytes as 64 hex chars)
# Generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=cb0f3e27ffa597fae91b55eedd11f3d220a43eb18356d8183df6dc2e171704b1
# CORS
CLIENT_URL=http://localhost:5173
