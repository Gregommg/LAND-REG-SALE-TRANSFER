# Only needed for PRODUCTION builds where the frontend and backend are
# deployed as separate services (e.g. Render, Vercel + Railway). In local
# development, leave these unset - the Vite dev server proxies /api and
# /uploads straight to http://localhost:5000 (see vite.config.js).

VITE_API_BASE_URL=https://your-backend-service.onrender.com/api
VITE_UPLOADS_BASE_URL=https://your-backend-service.onrender.com/uploads
